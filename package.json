{
  "name": "voke",
  "productName": "Voke",
  "version": "1.0.0",
  "description": "Voke - AI 智能语音交互助手。随时随地唤起 AI，语音转文字、LLM 问答、Agent 调度一体化。",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "concurrently -k -r \"npm:dev:renderer\" \"npm:dev:main\"",
    "dev:main": "cross-env NODE_ENV=development electron . --dev",
    "dev:renderer": "cd src && vite",
    "build": "cd src && vite build && cd .. && electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "build:renderer": "cd src && vite build",
    "prebuild:mac": "npm run build:renderer",
    "build:mac": "electron-builder --mac",
    "prebuild:win": "npm run build:renderer",
    "build:win": "electron-builder --win",
    "prebuild:linux": "npm run build:renderer",
    "build:linux": "electron-builder --linux",
    "pack": "npm run build:renderer && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "dist": "npm run build:renderer && electron-builder",
    "pack:win": "npm run build:renderer && electron-packager . Voke --platform=win32 --arch=x64 --out=release-builds-v2 --overwrite --prune=true --icon=assets/icon.ico",
    "pack:mac": "npm run build:renderer && electron-packager . Voke --platform=darwin --arch=x64 --out=release-builds-v2 --overwrite --prune=true --icon=assets/icon.icns",
    "lint": "cd src && eslint .",
    "preview": "cd src && vite preview",
    "clean": "node cleanup.js"
  },
  "keywords": [
    "dictation",
    "speech-to-text",
    "ai",
    "llm",
    "chinese",
    "electron",
    "desktop-app"
  ],
  "author": {
    "name": "zyk"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron/notarize": "^3.0.1",
    "@eslint/js": "^9.25.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@tailwindcss/vite": "^4.1.10",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "cross-env": "^10.0.0",
    "electron": "^36.5.0",
    "electron-builder": "^24.6.4",
    "electron-packager": "^17.1.2",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "node-gyp": "^11.4.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.10",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "asynckit": "^0.4.0",
    "axios": "^1.6.0",
    "better-sqlite3": "11.10.0",
    "bindings": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "combined-stream": "^1.0.8",
    "delayed-stream": "^1.0.0",
    "dotenv": "^16.3.1",
    "electron-updater": "^6.6.2",
    "es-errors": "^1.3.0",
    "es-object-atoms": "^1.1.1",
    "es-set-tostringtag": "^2.1.0",
    "ffmpeg-static": "^5.2.0",
    "file-uri-to-path": "^2.0.0",
    "form-data": "^4.0.4",
    "get-intrinsic": "^1.3.0",
    "iconv-lite": "^0.7.2",
    "lucide-react": "^0.518.0",
    "math-intrinsics": "^1.1.0",
    "mime-db": "^1.54.0",
    "mime-types": "^3.0.1",
    "next-themes": "^0.4.6",
    "openai": "^6.22.0",
    "osascript": "^1.0.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shadcn-ui": "^0.9.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.3.4",
    "uiohook-napi": "^1.5.4",
    "uuid": "^13.0.0"
  },
  "build": {
    "appId": "com.voke.app",
    "productName": "Voke",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "node_modules/**/*",
      "src/dist/**/*",
      "src/helpers/**/*",
      "src/utils/**/*",
      "assets/**/*",
      "!node_modules/.cache/**/*",
      "!src/node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/**/*ffmpeg-static*/**/*",
      "node_modules/**/*better-sqlite3*/**/*",
      "node_modules/**/*bindings*/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "notarize": {
        "teamId": "7MTHK6DGS4"
      }
    },
    "win": {
      "icon": "assets/icon.ico",
      "verifyUpdateCodeSignature": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Voke"
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Office"
    }
  }
}
